---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
---

<BaseLayout title="Projects" sideBarActiveItemID="services">
  <div>
    <div class="text-3xl w-full font-bold mb-5">What can I do for you?</div>
  </div>

  <HorizontalCard
    title="Dev"
    img="/post_img.webp"
    desc="Develop and deploy smart contracts according to your needs."
    url="#"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Audit"
    img="/post_img.webp"
    desc="Audit your smart contracts and make sure they are secure and optimized."
    url="#"
  />
  <div class="divider my-0"></div>
  <HorizontalCard
    title="Consulting"
    img="/post_img.webp"
    desc="Offer expertise and guidance on smart contract development and security for your project."
    url="#"
  />
  <div class="divider my-0"></div>

</BaseLayout>
